# S.A.M Mission Control — Environment Variables
# Copy to .env and fill in your values

# Option 1: Single URL
# SAM_DB_URL=mysql://user:password@host:port/database

# Option 2: Individual fields
SAM_DB_HOST=127.0.0.1
SAM_DB_PORT=3306
SAM_DB_USER=root
SAM_DB_PASS=your_password_here
SAM_DB_NAME=sam_fleet

# Hub node IP (skips SSH self-probe)
SAM_SELF_IP=10.0.0.1

# Your display name in chat
SAM_USER=operator

# Alert thresholds for proactive fleet health monitoring
ALERT_CPU_THRESHOLD=90
ALERT_RAM_THRESHOLD=90
ALERT_OFFLINE=true
