# Database connection - set one of:
# Option 1: Full URL
SAM_DB_URL=mysql://user:password@host:port/database

# Option 2: Individual components (used if SAM_DB_URL not set)
# SAM_DB_HOST=127.0.0.1
# SAM_DB_PORT=3306
# SAM_DB_USER=root
# SAM_DB_PASS=yourpassword
# SAM_DB_NAME=quantum_memory
# SAM_USER=operator  # Your display name in chat
